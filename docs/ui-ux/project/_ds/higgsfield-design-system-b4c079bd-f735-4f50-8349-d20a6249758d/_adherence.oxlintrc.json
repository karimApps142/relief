{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/feedback/**",
              "components/forms/**",
              "components/media/**",
              "ui_kits/web-app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Geist|Geist Mono))/i]",
        "message": "Font not provided by the design system. Available: Geist, Geist Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|name|size|square|ring|status|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: src, name, size, square, ring, status."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:xs|sm|md|lg|xl)$/]",
        "message": "<Avatar> size must be one of 'xs' | 'sm' | 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:online|busy|off)$/]",
        "message": "<Avatar> status must be one of 'online' | 'busy' | 'off'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|uppercase|dot|live|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, uppercase, dot, live, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:neutral|new|pro|accent|success|danger|info|outline)$/]",
        "message": "<Badge> variant must be one of 'neutral' | 'new' | 'pro' | 'accent' | 'success' | 'danger' | 'info' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|block|loading|iconOnly|leadingIcon|trailingIcon|as|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, block, loading, iconOnly, leadingIcon, trailingIcon, as."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|outline|accent|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'outline' | 'accent' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:button|a)$/]",
        "message": "<Button> as must be one of 'button' | 'a'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|padded|hover|title|action|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: variant, padded, hover, title, action, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|inset|glass)$/]",
        "message": "<Card> variant must be one of 'default' | 'inset' | 'glass'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Dialog'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|onClose|title|description|footer|className|children|key|ref|className|style|children)$/]",
        "message": "<Dialog> doesn't accept that prop. Declared props: open, onClose, title, description, footer, className, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|round|children|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: variant, size, round, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:ghost|solid|glass|primary)$/]",
        "message": "<IconButton> variant must be one of 'ghost' | 'solid' | 'glass' | 'primary'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<IconButton> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|error|size|leadingIcon|trailingIcon|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hint, error, size, leadingIcon, trailingIcon."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Input> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MediaCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|label|model|author|ratio|badge|showPlay|onClick|key|ref|className|style|children)$/]",
        "message": "<MediaCard> doesn't accept that prop. Declared props: src, label, model, author, ratio, badge, showPlay, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='MediaCard'] > JSXAttribute[name.name='ratio'] > Literal[value!=/^(?:16:9|1:1|9:16|4:5|3:2)$/]",
        "message": "<MediaCard> ratio must be one of '16:9' | '1:1' | '9:16' | '4:5' | '3:2'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ModelPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|isNew|active|chevron|key|ref|className|style|children)$/]",
        "message": "<ModelPill> doesn't accept that prop. Declared props: name, isNew, active, chevron."
      },
      {
        "selector": "JSXOpeningElement[name.name='ComposerReference'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|onRemove|key|ref|className|style|children)$/]",
        "message": "<ComposerReference> doesn't accept that prop. Declared props: src, onRemove."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|icon|key|ref|className|style|children)$/]",
        "message": "<SegmentOption> doesn't accept that prop. Declared props: value, label, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='SelectOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<SelectOption> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Slider'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|min|max|step|value|defaultValue|onChange|suffix|tone|showValue|key|ref|className|style|children)$/]",
        "message": "<Slider> doesn't accept that prop. Declared props: label, min, max, step, value, defaultValue, onChange, suffix, tone, showValue."
      },
      {
        "selector": "JSXOpeningElement[name.name='Slider'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:white|accent)$/]",
        "message": "<Slider> tone must be one of 'white' | 'accent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Spinner'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|accent|label|key|ref|className|style|children)$/]",
        "message": "<Spinner> doesn't accept that prop. Declared props: size, accent, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Spinner'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:xs|md|lg)$/]",
        "message": "<Spinner> size must be one of 'xs' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|defaultChecked|onChange|label|size|tone|disabled|className|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, defaultChecked, onChange, label, size, tone, disabled, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Switch> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:accent|white)$/]",
        "message": "<Switch> tone must be one of 'accent' | 'white'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:selected|size|icon|onRemove|onClick|children|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: selected, size, icon, onRemove, onClick, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Tag> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|title|message|onClose|className|key|ref|className|style|children)$/]",
        "message": "<Toast> doesn't accept that prop. Declared props: variant, title, message, onClose, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:success|danger|info|neutral)$/]",
        "message": "<Toast> variant must be one of 'success' | 'danger' | 'info' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tooltip'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|kbd|side|className|children|key|ref|className|style|children)$/]",
        "message": "<Tooltip> doesn't accept that prop. Declared props: label, kbd, side, className, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tooltip'] > JSXAttribute[name.name='side'] > Literal[value!=/^(?:top|bottom|left|right)$/]",
        "message": "<Tooltip> side must be one of 'top' | 'bottom' | 'left' | 'right'."
      }
    ]
  },
